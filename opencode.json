{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama (local)",
			"options": {
				"baseURL": "http://localhost:11434/v1"
			},
			"models": {
				"gemma4:e4b": {
					"name": "Gemma 4 E4B"
				}
			}
		}
	},
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": ["npx", "-y", "chrome-devtools-mcp@latest"]
		},
		"angular-cli": {
			"type": "local",
			"command": ["npx", "-y", "@angular/cli", "mcp"]
		}
	}
}
